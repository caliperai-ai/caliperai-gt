# Production Environment Configuration
# ================================================================================
# SECURITY WARNING: Keep this file secure and never commit to version control!
# Copy this file to .env and configure all values before deployment.
# ================================================================================
#
# See the "Production Deployment" section of the README for the full guide.
#
# ================================================================================

# =============================================================================
# REQUIRED SECRETS (Generate unique values for production!)
# =============================================================================

# Database password - CHANGE THIS!
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Application secret key for JWT tokens - CHANGE THIS!
# Generate with: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING

# Redis password - CHANGE THIS!
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# MinIO credentials - CHANGE THESE!
# Generate with: openssl rand -base64 24
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# =============================================================================
# DOMAIN & SSL CONFIGURATION
# =============================================================================

# Your domain name (without https://)
# Example: annotate.example.com
DOMAIN=your-domain.com

# CORS origins - comma-separated list of allowed origins
# When behind reverse proxy, include the public URL
CORS_ORIGINS=https://your-domain.com

# SSL certificate paths (only needed if NOT using external reverse proxy)
# When using system nginx with Let's Encrypt, these are not mounted
SSL_CERT_PATH=./certs/fullchain.pem
SSL_KEY_PATH=./certs/privkey.pem

# =============================================================================
# PORT CONFIGURATION
# =============================================================================

# Frontend port (when behind reverse proxy, use non-standard port)
# System nginx proxies to this port
FRONTEND_PORT=3100

# SAM2 GPU service port (if using GPU features)
SAM2_PORT=8001

# =============================================================================
# RESOURCE LIMITS
# =============================================================================

# Backend API
BACKEND_WORKERS=4                    # Uvicorn workers (recommended: 2 * CPU cores + 1)
BACKEND_CPU_LIMIT=4                  # Max CPU cores
BACKEND_MEMORY_LIMIT=4G              # Max memory

# PostgreSQL
PG_CPU_LIMIT=4
PG_MEMORY_LIMIT=2G
PG_SHARED_BUFFERS=256MB              # 25% of PG_MEMORY_LIMIT
PG_EFFECTIVE_CACHE=1GB               # 50-75% of PG_MEMORY_LIMIT
PG_WORK_MEM=16MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_MAX_CONNECTIONS=200

# Redis
REDIS_CPU_LIMIT=1
REDIS_MEMORY_LIMIT=1G
REDIS_MAXMEMORY=512mb

# MinIO
MINIO_CPU_LIMIT=2
MINIO_MEMORY_LIMIT=1G

# Nginx
NGINX_CPU_LIMIT=2
NGINX_MEMORY_LIMIT=512M

# Database connection pool
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info                       # debug, info, warning, error

# PostgreSQL slow query log threshold (ms)
PG_LOG_MIN_DURATION=1000

# =============================================================================
# SAM2 GPU CONFIGURATION (if using docker-compose.gpu.yml)
# =============================================================================

SAM2_MODE=api                        # 'api' to use separate GPU service
SAM2_MODEL_SIZE=large                # tiny, small, base, large
SAM2_DEVICE=cuda                     # cuda or cpu

# =============================================================================
# AI CHATBOT / OLLAMA LLM CONFIGURATION
# =============================================================================

LLM_PROVIDER=ollama                  # ollama, vllm, or mock (for testing)
OLLAMA_BASE_URL=http://ollama:11434  # Ollama service URL (internal)
OLLAMA_MODEL=mistral:7b-instruct    # Default model to use

# Ollama resource limits (CPU mode in docker-compose.prod.yml)
OLLAMA_CPU_LIMIT=4
OLLAMA_MEMORY_LIMIT=8G

# For GPU mode (docker-compose.prod.gpu.yml), increase limits:
# OLLAMA_CPU_LIMIT=8
# OLLAMA_MEMORY_LIMIT=16G

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

BACKUP_RETENTION_DAYS=7              # How many days to keep backups

# =============================================================================
# OBJECT STORAGE
# =============================================================================

OBJECT_STORAGE_BUCKET=annotation-data

# Enable/disable MinIO web console
MINIO_BROWSER=off                    # Disable in production for security

# =============================================================================
# VERSION TAGGING
# =============================================================================

VERSION=1.0.0                        # Docker image version tag
