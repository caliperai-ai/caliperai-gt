import { create } from 'zustand';
import { v4 as uuidv4 } from 'uuid';
import type { 
  Annotation, 
  CuboidData, 
  Track, 
  TrackKeyframe, 
  InterpolatedFrame,
  AnnotationType,
  AnnotationSource 
} from '@/types';
import { useEditorStore } from './editorStore';
