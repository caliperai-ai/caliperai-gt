# Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Database
# =============================================================================
POSTGRES_PASSWORD=change-in-production
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@localhost:5432/annotation_platform

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
# Must be at least 32 characters. Generate: openssl rand -hex 32
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Object Storage (MinIO)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=annotation-data
# At-rest encryption. Leave "off" for local dev; "on" requires MINIO_KMS_SECRET_KEY.
MINIO_KMS_AUTO_ENCRYPTION=off

# =============================================================================
# Ports
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# Build Configuration
# =============================================================================
# 'production' builds the frontend and serves it via nginx on port 80 (which is
# what the compose port mapping 3000:80 and the healthcheck expect) — use this
# for the Quick Start. Only switch to 'development' (Vite dev server on 5173) if
# you also remap the frontend port to :5173; otherwise the frontend will be
# unreachable and report unhealthy.
BUILD_TARGET=production

# =============================================================================
# AI Chatbot / LLM Configuration
# =============================================================================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_PORT=11434
